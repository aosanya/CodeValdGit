# ArangoDB connection for integration tests (storage/arangodb)
# Copy to .env and fill in your values:
#   cp .env.example .env

ARANGODB_URL=http://localhost:8529
ARANGODB_USER=root
ARANGODB_PASS=

# -------------------------------------------------------------------
# CodeValdCross registration heartbeat
# -------------------------------------------------------------------

# How often (in seconds) CodeValdGit sends a Register heartbeat to CodeValdCross.
# CODEVALDGIT_PING_INTERVAL=10

# Per-RPC timeout (in seconds) for each Register call to CodeValdCross.
# CODEVALDGIT_PING_TIMEOUT=5
